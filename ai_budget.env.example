# Fill in your own keys and budget amounts in USD.
# Left click a budget module resets its session counter.
# Right click forces a fresh API fetch.

OPENAI_ADMIN_KEY=
OPENAI_API_KEY=
OPENAI_WEEKLY_BUDGET_USD=25
OPENAI_SESSION_BUDGET_USD=5

ANTHROPIC_ADMIN_API_KEY=
ANTHROPIC_WEEKLY_BUDGET_USD=25
ANTHROPIC_SESSION_BUDGET_USD=5

# Gemini support reads the latest Cloud Billing budget notification JSON.
# Set this to a JSON file produced by a Pub/Sub subscriber or another sync job.
GEMINI_BUDGET_STATUS_FILE=~/.config/polybar/gemini_budget.json
GEMINI_WEEKLY_BUDGET_USD=25
GEMINI_SESSION_BUDGET_USD=5
